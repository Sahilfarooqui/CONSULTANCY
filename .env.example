# Runway2Sky — copy to .env and fill in free API keys for full auto job feed

# --- Strongly recommended (FREE) — real airline/airport jobs worldwide ---
# Sign up: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Optional: comma-separated country codes (default includes ae,gb,us,in,sa,...)
# ADZUNA_COUNTRIES=ae,gb,us,in,sa,qa,sg
# ADZUNA_MAX_CALLS=24

# --- Optional — Google for Jobs / LinkedIn-indexed listings via RapidAPI ---
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=

# Server
PORT=4000
JOBS_CACHE_MS=3600000
REFRESH_SECRET=change-me-for-manual-refresh

# Frontend (optional absolute API URL in production)
# REACT_APP_JOBS_API_URL=https://runway2sky.online/api/jobs
